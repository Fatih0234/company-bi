{
  "type": "evidence",
  "projectId": "company-bi",
  "port": 3000,
  "agentCommand": "./bin/lumen-pi",
  "devCommand": "npm run dev",
  "url": "http://localhost:3000",
  "workspaceDir": ".workspaces",
  "registryPath": ".cmux/registry.json",
  "workspaceMode": "content-only",
  "runtimeDir": "~/.local/share/lumen-bi/runtime/company-bi",
  "analysisBasePort": 3100,
  "validateCommand": "npm run build",
  "onboardingAi": {
    "provider": "opencode",
    "model": "mimo-v2.5-free",
    "thinking": "medium"
  },
  "contentVisiblePaths": ["pages/**", "queries/**", "reports/**", "data/**"],
  "allowedAgentPaths": ["pages/**", "queries/**", "reports/**", "data/**", ".cmux/workspace.json", ".cmux/data-profile.json", ".pi/duckdb/**"],
  "askBeforeAgentPaths": ["sources/**", "components/**"],
  "blockedAgentPaths": [".env*", "**/connection.yaml", ".github/**", "package.json", "package-lock.json", "bin/**", "scripts/**", ".pi/extensions/**"]
}
