#!/usr/bin/env python3
"""Open CMUX + Evidence workspaces."""

from __future__ import annotations

import fnmatch
import json
import os
import re
import difflib
import hashlib
import shutil
import socket
import subprocess
import sys
import urllib.parse
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

# Ensure the scripts directory is importable for workspace_data_registry
_SCRIPTS_DIR = str(Path(__file__).resolve().parent.parent / "scripts")
if _SCRIPTS_DIR not in sys.path:
    sys.path.insert(0, _SCRIPTS_DIR)
import workspace_data_registry as wdr


DEFAULT_PORT = 3000
DEFAULT_ANALYSIS_BASE_PORT = 3100
PORT_RANGE_SIZE = 100
DEFAULT_REGISTRY_PATH = ".cmux/registry.json"
DEFAULT_WORKSPACE_MODE = "git-worktree"
CONTENT_WORKSPACE_MODE = "content-only"

_STYLE_CODES = {
    "reset": "\033[0m",
    "bold": "\033[1m",
    "dim": "\033[2m",
    "cyan": "\033[36m",
    "green": "\033[32m",
    "yellow": "\033[33m",
    "red": "\033[31m",
    "muted": "\033[90m",
}


def use_color() -> bool:
    return sys.stdout.isatty() and os.environ.get("NO_COLOR") is None and os.environ.get("TERM") != "dumb"


def style(text: str, *, color: str | None = None, bold: bool = False, dim: bool = False) -> str:
    if not use_color():
        return text
    prefixes: list[str] = []
    if bold:
        prefixes.append(_STYLE_CODES["bold"])
    if dim:
        prefixes.append(_STYLE_CODES["dim"])
    if color:
        prefixes.append(_STYLE_CODES.get(color, ""))
    return "".join(prefixes) + text + _STYLE_CODES["reset"] if prefixes else text


def heading(text: str) -> str:
    return style(text, color="cyan", bold=True)


def muted(text: str) -> str:
    return style(text, color="muted", dim=True)


def success_text(text: str) -> str:
    return style(text, color="green")


def warning_text(text: str) -> str:
    return style(text, color="yellow")


def error_text(text: str) -> str:
    return style(text, color="red")


def error(message: str) -> int:
    print(message, file=sys.stderr)
    return 2


def run_git(root: Path, args: list[str], *, check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", *args],
        cwd=root,
        check=check,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def git_root(path: Path) -> Path | None:
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            cwd=path,
            check=True,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
        )
    except subprocess.CalledProcessError:
        return None
    return Path(result.stdout.strip()).resolve()


def expand_path(value: str, *, base: Path | None = None) -> Path:
    expanded = os.path.expandvars(os.path.expanduser(value))
    path = Path(expanded)
    if not path.is_absolute() and base is not None:
        path = base / path
    return path.resolve()


def project_id(root: Path, config: dict[str, Any]) -> str:
    return str(config.get("projectId") or root.name)


def registry_path(root: Path, config: dict[str, Any]) -> Path:
    raw = str(config.get("registryPath") or DEFAULT_REGISTRY_PATH)
    return expand_path(raw, base=root)


def workspace_mode(config: dict[str, Any]) -> str:
    mode = str(config.get("workspaceMode") or DEFAULT_WORKSPACE_MODE).strip()
    return mode or DEFAULT_WORKSPACE_MODE


def workspace_dir(root: Path, config: dict[str, Any]) -> Path:
    raw = str(config.get("workspaceDir") or ".workspaces")
    return expand_path(raw, base=root)


def runtime_root(root: Path, config: dict[str, Any]) -> Path:
    raw = str(config.get("runtimeRoot") or root)
    return expand_path(raw, base=root)


def runtime_dir(root: Path, config: dict[str, Any]) -> Path:
    pid = project_id(root, config)
    raw = str(config.get("runtimeDir") or f"~/.local/share/lumen-bi/runtime/{pid}")
    return expand_path(raw, base=root)


def load_registry(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {"version": 1, "projects": {}}
    try:
        registry = json.loads(path.read_text())
    except json.JSONDecodeError as exc:
        raise ValueError(f"Invalid JSON in registry {path}: {exc}") from exc
    if not isinstance(registry, dict):
        raise ValueError(f"Invalid registry {path}: expected a JSON object")
    registry.setdefault("version", 1)
    registry.setdefault("projects", {})
    return registry


def save_registry(path: Path, registry: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(registry, indent=2, sort_keys=True) + "\n")
    tmp.replace(path)


def upsert_workspace_registry(
    *,
    registry_file: Path,
    project_id_value: str,
    project_root: Path,
    workspace: dict[str, Any],
) -> None:
    registry = load_registry(registry_file)
    projects = registry.setdefault("projects", {})
    project = projects.setdefault(
        project_id_value,
        {"root": str(project_root), "workspaces": {}},
    )
    project["root"] = str(project_root)
    project.setdefault("workspaces", {})[workspace["slug"]] = workspace
    save_registry(registry_file, registry)


def load_config(marker: Path) -> dict[str, Any]:
    try:
        config = json.loads(marker.read_text())
    except json.JSONDecodeError as exc:
        raise ValueError(f"Invalid JSON in {marker}: {exc}") from exc

    if not isinstance(config, dict):
        raise ValueError(f"Invalid {marker}: expected a JSON object")

    marker_type = config.get("type")
    if marker_type != "evidence":
        raise ValueError(f"Invalid {marker}: expected type='evidence', got {marker_type!r}")

    return config


def load_project(target: Path) -> tuple[Path, dict[str, Any]]:
    target = target.expanduser().resolve()
    if not target.exists() or not target.is_dir():
        raise ValueError(f"Target is not a directory: {target}")

    marker = target / ".cmux" / "evidence.json"
    if not marker.exists():
        raise ValueError(f"Not an Evidence CMUX workspace: {target}\nMissing .cmux/evidence.json")

    return target, load_config(marker)


def load_current_project() -> tuple[Path, dict[str, Any]]:
    cwd = Path.cwd().resolve()
    root = git_root(cwd)
    if root is not None:
        return load_project(root)

    local_marker = cwd / ".cmux" / "evidence.json"
    if local_marker.exists():
        local_config = load_config(local_marker)
        configured_runtime_root = local_config.get("runtimeRoot")
        if configured_runtime_root:
            return load_project(expand_path(str(configured_runtime_root), base=cwd))
        return cwd, local_config

    raise ValueError("Not inside a Git repository or Evidence CMUX workspace")


def slugify(value: str) -> str:
    value = value.lower()
    value = re.sub(r"[^a-z0-9]+", "-", value)
    value = value.strip("-")
    return value or "untitled-analysis"


def branch_exists(root: Path, branch: str) -> bool:
    result = run_git(root, ["rev-parse", "--verify", branch], check=False)
    return result.returncode == 0


def unique_slug(base_slug: str, root: Path, workspaces_root: Path) -> str:
    slug = base_slug
    i = 2
    while (workspaces_root / slug).exists() or branch_exists(root, f"analysis/{slug}"):
        slug = f"{base_slug}-{i}"
        i += 1
    return slug


def port_is_free(port: int) -> bool:
    checks = [
        (socket.AF_INET, "127.0.0.1"),
        (socket.AF_INET6, "::1"),
    ]
    for family, host in checks:
        try:
            with socket.socket(family, socket.SOCK_STREAM) as s:
                s.settimeout(0.25)
                if s.connect_ex((host, port)) == 0:
                    return False
        except OSError:
            continue
    return True


def used_workspace_ports(workspaces_root: Path) -> set[int]:
    ports: set[int] = set()
    if not workspaces_root.exists():
        return ports

    for path in workspaces_root.glob("*/.cmux/*.json"):
        try:
            data = json.loads(path.read_text())
        except (OSError, json.JSONDecodeError):
            continue
        if not isinstance(data, dict):
            continue
        try:
            ports.add(int(data["port"]))
        except (KeyError, TypeError, ValueError):
            continue

    return ports


def registry_workspace_ports(registry_file: Path, project_id_value: str) -> set[int]:
    ports: set[int] = set()
    try:
        registry = load_registry(registry_file)
    except ValueError:
        return ports
    workspaces = registry.get("projects", {}).get(project_id_value, {}).get("workspaces", {})
    if not isinstance(workspaces, dict):
        return ports
    for row in workspaces.values():
        if not isinstance(row, dict):
            continue
        try:
            ports.add(int(row["port"]))
        except (KeyError, TypeError, ValueError):
            continue
    return ports


def choose_port(base_port: int, workspaces_root: Path, *, extra_used_ports: set[int] | None = None) -> int:
    used_ports = used_workspace_ports(workspaces_root) | (extra_used_ports or set())
    for port in range(base_port, base_port + PORT_RANGE_SIZE):
        if port not in used_ports and port_is_free(port):
            return port
    raise RuntimeError(
        f"No free Evidence analysis ports found in range {base_port}-{base_port + PORT_RANGE_SIZE - 1}"
    )


def build_layout(
    *,
    target: Path,
    url: str,
    agent_command: str,
    dev_command: str,
    agent_cwd: Path | None = None,
    dev_cwd: Path | None = None,
) -> dict[str, Any]:
    # Schema matches `cmux new-workspace --layout` / cmux.json layout definitions.
    return {
        "direction": "horizontal",
        "split": 0.5,
        "children": [
            {
                "pane": {
                    "surfaces": [
                        {
                            "type": "terminal",
                            "title": "Pi Agent",
                            "command": agent_command,
                            "cwd": str(agent_cwd or target),
                            "focus": True,
                        }
                    ]
                }
            },
            {
                "direction": "vertical",
                "split": 0.58,
                "children": [
                    {
                        "pane": {
                            "surfaces": [
                                {
                                    "type": "browser",
                                    "title": "Evidence Preview",
                                    "url": url,
                                }
                            ]
                        }
                    },
                    {
                        "pane": {
                            "surfaces": [
                                {
                                    "type": "terminal",
                                    "title": "Evidence Dev",
                                    "command": dev_command,
                                    "cwd": str(dev_cwd or target),
                                }
                            ]
                        }
                    },
                ],
            },
        ],
    }


def open_workspace(target_arg: str | Path = ".", *, print_layout: bool = False) -> int:
    try:
        target, config = load_project(Path(target_arg))
        port = int(config.get("port", DEFAULT_PORT))
    except (TypeError, ValueError) as exc:
        return error(str(exc))

    url = str(config.get("url") or f"http://localhost:{port}")
    agent_command = str(config.get("agentCommand") or "pi")
    dev_command = str(config.get("devCommand") or "npm run dev")
    metadata = load_workspace_metadata(target) or {}
    try:
        repaired_shadow_root = ensure_content_shadow_runtime(target, config, metadata)
    except ValueError as exc:
        return error(str(exc))
    agent_cwd = Path(str(metadata.get("workspaceRoot") or target)).expanduser().resolve()
    dev_cwd = repaired_shadow_root if is_content_workspace(config, metadata) else Path(str(metadata.get("shadowRuntimeRoot") or target)).expanduser().resolve()

    layout = build_layout(
        target=target,
        url=url,
        agent_command=agent_command,
        dev_command=dev_command,
        agent_cwd=agent_cwd,
        dev_cwd=dev_cwd,
    )

    if print_layout:
        print(json.dumps(layout, indent=2))
        return 0

    real_cmux = (
        os.environ.get("CMUX_EVIDENCE_REAL_CMUX")
        or os.environ.get("CMUX_REAL_BIN")
        or shutil.which("cmux")
    )
    if not real_cmux:
        return error("Could not find cmux binary")

    command = [
        real_cmux,
        "workspace",
        "create",
        "--name",
        target.name,
        "--cwd",
        str(target),
        "--layout",
        json.dumps(layout, separators=(",", ":")),
        "--focus",
        "true",
    ]

    try:
        completed = subprocess.run(command, check=False)
    except OSError as exc:
        return error(f"Failed to run cmux: {exc}")

    return completed.returncode


def resolve_registered_workspace(slug: str) -> Path:
    root, config = load_current_project()
    pid = project_id(root, config)
    registry_file = registry_path(root, config)
    registry = load_registry(registry_file)
    workspace = registry.get("projects", {}).get(pid, {}).get("workspaces", {}).get(slug)
    if not workspace:
        raise ValueError(f"No analysis workspace found for {pid}: {slug}")
    path = Path(str(workspace.get("path") or "")).expanduser().resolve()
    if not path.exists() or not path.is_dir():
        raise ValueError(f"Registered workspace path does not exist for {slug}: {path}")
    return path


def open_analysis(target_arg: str | Path = ".", *, print_layout: bool = False) -> int:
    target_text = str(target_arg)
    expanded = expand_path(target_text) if target_text not in {"", "."} else Path(".").resolve()
    if expanded.exists() and expanded.is_dir():
        return open_workspace(expanded, print_layout=print_layout)

    try:
        target = resolve_registered_workspace(target_text)
    except ValueError as exc:
        return error(str(exc))
    return open_workspace(target, print_layout=print_layout)


def render_brief_page(title: str, metadata: dict[str, Any] | None = None) -> str:
    intention = metadata.get("intention") if isinstance(metadata, dict) else None
    intention = intention if isinstance(intention, dict) else {}

    def list_value(key: str) -> list[str]:
        value = intention.get(key)
        if not isinstance(value, list):
            return []
        rendered: list[str] = []
        for item in value:
            if isinstance(item, dict):
                question = str(item.get("question") or "").strip()
                answer = str(item.get("answer") or "").strip()
                if question and answer:
                    rendered.append(f"{question} — {answer}")
                elif question or answer:
                    rendered.append(question or answer)
            else:
                text = str(item).strip()
                if text:
                    rendered.append(text)
        return rendered

    def bullets(values: list[str], fallback: str = "Not specified yet.") -> str:
        return "\n".join(f"- {value}" for value in values) if values else fallback

    def checklist(values: list[str], fallback_items: list[str]) -> str:
        items = values or fallback_items
        return "\n".join(f"- [ ] {value}" for value in items)

    goal = str(intention.get("goal") or "").strip() or "Describe the business question this dashboard should answer."
    questions = list_value("questions")
    stakeholders = list_value("stakeholders")
    success_criteria = list_value("successCriteria")
    dashboard_options = list_value("dashboardOptions")
    assumptions = list_value("assumptions")
    clarifications = list_value("clarifications")
    open_questions = list_value("openQuestions")

    dashboard_checklist = checklist(
        dashboard_options,
        [
            "Create KPI cards for the core operating metrics.",
            "Add at least one trend chart for time-based analysis.",
            "Add a ranking table or chart for important dimensions.",
            "Add useful filters if the data supports them.",
            "Validate the rendered dashboard in the CMUX browser preview.",
        ],
    )

    title_yaml = json.dumps(title)

    return f"""---
title: {title_yaml}
---

# {title}

This is your analysis workspace home page. Use it to keep the goal, working files, and publish plan clear while Pi helps build the dashboard.

## Start Here

1. Explore ideas and rough queries in `pages/draft.md`.
2. Save reusable analysis SQL in `queries/`.
3. Move validated findings into `pages/report.md`.
4. Preview the workspace at the URL shown by `cmux-evidence current` or `cmux-evidence preview-url`.
5. Publish only when `pages/report.md` is ready to share.

## Files in this workspace

| Path | Purpose | Published by default? |
|------|---------|-----------------------|
| `pages/index.md` | This brief and workspace map | No |
| `pages/draft.md` | Private exploration, scratch queries, working notes | No |
| `pages/report.md` | Polished report/dashboard | Yes |
| `queries/` | Reusable analysis-owned SQL | Yes |
| `data/` | Local input files for this analysis | No |
| `reports/` | Optional local or curated report materials | No |

## Publish & privacy

Publishing shares `pages/report.md` and `queries/**` by default. Draft notes, local data, DuckDB scratch files, and runtime files stay private unless you explicitly choose otherwise.

## Workspace Brief

### Goal

{goal}

### Questions this dashboard should answer

{bullets(questions)}

### Stakeholders / audience

{bullets(stakeholders)}

### Success criteria

{bullets(success_criteria)}

### Proposed dashboard direction

{bullets(dashboard_options)}

### Assumptions

{bullets(assumptions)}

### Clarifications captured during onboarding

{bullets(clarifications, "No clarifications captured yet.")}

### Open questions

{bullets(open_questions, "No open questions captured yet.")}

## Build Checklist

Pi should update this checklist as it turns the brief into an Evidence dashboard.

{dashboard_checklist}

## Workspace Pages

| Page | Path | Purpose | Status |
|------|------|---------|--------|
| Brief | `pages/index.md` | This workspace map and intention | ✅ Active |
| Draft | `pages/draft.md` | Exploration, hypothesis testing, messy queries | 🔄 Active |
| Report | `pages/report.md` | Polished dashboard with validated findings | 📝 Not started |

The **Draft** page is the sandbox. Put experiments, raw queries, and work-in-progress there.
Use `queries/` for reusable analysis-owned SQL files that belong with this workspace.
The **Report** page is the polished dashboard. Move validated findings there.
This **Brief** page (this page) is the workspace map and intention.

## Collaboration notes

- Keep the Workspace Brief aligned with `.cmux/workspace.json` when the user's goal changes.
- Prefer Evidence-native Markdown, SQL, KPI cards, charts, filters, and tables.
- Use the CMUX browser preview to verify visible dashboard quality after meaningful edits.
"""


def write_brief_page(path: Path, title: str, metadata: dict[str, Any] | None = None) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(render_brief_page(title, metadata))


def render_draft_page(title: str) -> str:
    title_yaml = json.dumps(title)
    return f"""---
title: {title_yaml}
---

# Draft: {title}

This is the private exploration sandbox for this analysis. Use it for messy queries, experiments, working notes, and candidate findings before moving polished content to `pages/report.md`.

## Questions to explore

- What needs to be true for this dashboard to answer the brief?
- Which metrics, trends, or segments should Pi investigate first?

## Working notes

_Add rough observations here as you explore._

## Scratch query

Replace this placeholder with real exploration. Put reusable SQL that should be preserved in `queries/`.

```sql draft_query
select 1 as example_metric
```

<DataTable data={{draft_query}} />

## Candidate findings

- Move validated findings to `pages/report.md`.
- Keep reusable analysis SQL in `queries/`.
- Update `pages/index.md` when you create new pages or change the analysis direction.
"""


def write_draft_page(path: Path, title: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(render_draft_page(title))


def render_report_page(title: str) -> str:
    title_yaml = json.dumps(title)
    return f"""---
title: {title_yaml}
---

# Report: {title}

This is the polished report for validated findings. By default, publishing shares this page at `/reports/<workspace-slug>/` together with `queries/**`. Draft notes, local data, DuckDB scratch files, and runtime files stay private.

## Executive Summary

_To be completed._

## Key Metrics

_To be completed._

## Trend

_To be completed._

## Breakdown

_To be completed._

## Assumptions and Caveats

_To be completed._

## Next Steps

_To be completed._
"""


def write_report_page(path: Path, title: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(render_report_page(title))


def symlink_or_copy(source: Path, target: Path) -> None:
    if target.exists() or target.is_symlink():
        return
    target.parent.mkdir(parents=True, exist_ok=True)
    try:
        target.symlink_to(source, target_is_directory=source.is_dir())
        return
    except OSError:
        pass
    if source.is_dir():
        shutil.copytree(source, target, dirs_exist_ok=True)
    elif source.exists():
        shutil.copy2(source, target)


def write_json(path: Path, data: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2) + "\n")


def string_list_config(config: dict[str, Any], key: str, default: list[str]) -> list[str]:
    value = config.get(key) or default
    if not isinstance(value, list):
        return default
    return [str(item) for item in value]


def render_intention_context(metadata: dict[str, Any]) -> str:
    intention = metadata.get("intention")
    if not isinstance(intention, dict):
        return ""

    scalar_goal = str(intention.get("goal") or "").strip()
    has_any_value = bool(scalar_goal)
    for key in ["questions", "dashboardOptions", "stakeholders", "successCriteria", "assumptions", "clarifications", "openQuestions"]:
        value = intention.get(key)
        if isinstance(value, list) and any(str(item).strip() for item in value):
            has_any_value = True
            break
    if not has_any_value:
        return ""

    def list_value(key: str) -> list[str]:
        value = intention.get(key)
        if not isinstance(value, list):
            return []
        return [str(item).strip() for item in value if str(item).strip()]

    def bullets(values: list[str]) -> str:
        return "\n".join(f"- {value}" for value in values) if values else "- Not specified"

    goal = scalar_goal or "Not specified"
    sections = [
        "## Analysis intention",
        "",
        "This workspace has an explicit analytical brief. Preserve and use it as the default direction for dashboard decisions unless the user changes it.",
        "",
        "### Goal",
        "",
        goal,
        "",
        "### Questions to answer",
        "",
        bullets(list_value("questions")),
        "",
        "### Stakeholders / audience",
        "",
        bullets(list_value("stakeholders")),
        "",
        "### Success criteria",
        "",
        bullets(list_value("successCriteria")),
    ]

    dashboard_options = list_value("dashboardOptions")
    if dashboard_options:
        sections.extend(["", "### Evidence dashboard direction", "", bullets(dashboard_options)])

    assumptions = list_value("assumptions")
    if assumptions:
        sections.extend(["", "### Assumptions", "", bullets(assumptions)])

    clarifications = intention.get("clarifications")
    if isinstance(clarifications, list) and clarifications:
        rendered = []
        for item in clarifications:
            if isinstance(item, dict):
                question = str(item.get("question") or "").strip()
                answer = str(item.get("answer") or "").strip()
                if question or answer:
                    rendered.append(f"- {question}: {answer}" if question and answer else f"- {question or answer}")
            elif str(item).strip():
                rendered.append(f"- {str(item).strip()}")
        if rendered:
            sections.extend(["", "### Clarifications", "", "\n".join(rendered)])

    open_questions = list_value("openQuestions")
    if open_questions:
        sections.extend(["", "### Open questions", "", bullets(open_questions)])

    sections.extend(
        [
            "",
            "When proposing or editing the dashboard, map each major element back to the goal, questions, stakeholders, or success criteria above.",
        ]
    )
    return "\n".join(sections)


def render_pi_context(
    *,
    project_id_value: str,
    title: str,
    slug: str,
    branch: str,
    worktree_path: Path,
    page: str,
    port: int,
    url: str,
    config: dict[str, Any],
    metadata: dict[str, Any] | None = None,
) -> str:
    metadata = metadata or {}
    allowed = string_list_config(config, "allowedAgentPaths", ["pages/**", "queries/**"])
    ask = string_list_config(
        config,
        "askBeforeAgentPaths",
        ["components/**", "sources/**", "package.json", "package-lock.json"],
    )
    blocked = string_list_config(
        config,
        "blockedAgentPaths",
        [".env*", "**/connection.yaml", ".github/**"],
    )
    content_mode = is_content_workspace(config, metadata)
    runtime_root_value = Path(str(metadata.get("runtimeRoot") or config.get("runtimeRoot") or worktree_path)).expanduser().resolve()
    shadow_root_value = metadata.get("shadowRuntimeRoot") or config.get("shadowRuntimeRoot")
    helper_command = runtime_root_value / "bin" / "cmux-evidence"

    def bullets(values: list[str]) -> str:
        return "\n".join(f"- {value}" for value in values)

    intention_context = render_intention_context(metadata)
    intention_block = f"\n{intention_context}\n" if intention_context else ""
    branch_line = f"- Branch: {branch}\n" if branch else ""
    if content_mode:
        root_lines = [
            "- Workspace mode: content-only",
            f"- Workspace root: {worktree_path}",
            f"- Runtime root: {runtime_root_value} (runtime-managed; do not edit unless explicitly asked)",
        ]
        if shadow_root_value:
            root_lines.append(f"- Shadow runtime: {Path(str(shadow_root_value)).expanduser().resolve()} (generated Evidence app; do not edit directly)")
        root_block = "\n".join(root_lines)
        source_guidance = "Runtime source files are read-only references for analysis context. Prefer editing pages, queries, reports, data, and approved workspace metadata."
    else:
        root_block = f"- Worktree: {worktree_path}"
        source_guidance = "Follow the safe edit policy below for source, component, package, and workspace files."

    return f"""# Evidence Dashboard Workspace Context

You are helping build an Evidence dashboard inside a CMUX workspace.

## Active analysis

- Project: {project_id_value}
- Title: {title}
- Slug: {slug}
{branch_line}{root_block}
- Primary page: {page}
- Preview URL: {url}
- Dev server port: {port}
- Workspace helper: {helper_command}
{intention_block}
## Main task

Help the user create and refine the Evidence dashboard for this analysis.
The workspace has three pages: Brief (index.md), Draft (draft.md), and Report (report.md), plus `queries/` for reusable analysis-owned SQL.
Start with the Draft page for exploration unless the user asks for a different target.

## Safe edit policy

{source_guidance}

Allowed by default:

{bullets(allowed)}

Ask before editing:

{bullets(ask)}

Do not edit:

{bullets(blocked)}

## CMUX workflow

When making dashboard changes:

1. Inspect the relevant Evidence files.
2. Make a small, focused edit.
3. Check the Evidence preview in the CMUX browser pane when possible.
4. Fix visible Evidence errors before saying the task is complete.
5. Summarize changed files and remaining questions.

Use `{helper_command}` for workspace commands such as `preview-url`, `status`, and `validate`.
Use CMUX status/progress/notifications for long-running work when available.
"""


def write_pi_context(target: Path, metadata: dict[str, Any], config: dict[str, Any]) -> Path:
    context_path = target / ".cmux" / "pi-context.md"
    context_path.parent.mkdir(parents=True, exist_ok=True)
    context_path.write_text(
        render_pi_context(
            project_id_value=str(metadata.get("projectId") or project_id(target, config)),
            title=str(metadata.get("title") or target.name),
            slug=str(metadata.get("slug") or target.name),
            branch=str(metadata.get("branch") or ""),
            worktree_path=Path(str(metadata.get("path") or target)).expanduser().resolve(),
            page=str(metadata.get("page") or ""),
            port=int(metadata.get("port") or config.get("port") or DEFAULT_PORT),
            url=str(metadata.get("url") or config.get("url") or ""),
            config=config,
            metadata=metadata,
        )
    )
    return context_path


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def copy_project_subdir(project_root: Path, worktree_path: Path, relative_path: str) -> None:
    source = project_root / relative_path
    if not source.exists():
        return
    target = worktree_path / relative_path
    if source.is_dir():
        shutil.copytree(source, target, dirs_exist_ok=True)
    else:
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, target)


def copy_project_skill(project_root: Path, worktree_path: Path, skill_name: str) -> None:
    copy_project_subdir(project_root, worktree_path, str(Path("pi-pkg") / "skills" / skill_name))


def copy_project_extension(project_root: Path, worktree_path: Path, extension_name: str) -> None:
    copy_project_subdir(project_root, worktree_path, str(Path("pi-pkg") / "extensions" / extension_name))


def prompt_line(label: str, *, default: str = "") -> str:
    suffix = muted(f" [{default}]") if default else ""
    value = input(f"{style(label, bold=True)}{suffix}: ").strip()
    return value or default


def workspace_minimal_evidence_config(
    *,
    root_config: dict[str, Any],
    pid: str,
    port: int,
    url: str,
    workspace_root: Path,
    shadow_root: Path,
    root: Path,
) -> dict[str, Any]:
    config = dict(root_config)
    config.update(
        {
            "type": "evidence",
            "projectId": pid,
            "workspaceMode": CONTENT_WORKSPACE_MODE,
            "port": port,
            "url": url,
            "runtimeRoot": str(root),
            "shadowRuntimeRoot": str(shadow_root),
            "workspaceRoot": str(workspace_root),
            "registryPath": str(registry_path(root, root_config)),
            "agentCommand": str(root / "bin" / "pi-full"),
            "devCommand": f"npm run dev -- --port {port}",
            "validateCommand": "npm run build",
        }
    )
    return config


def shadow_evidence_config(
    *,
    root_config: dict[str, Any],
    pid: str,
    port: int,
    url: str,
    workspace_root: Path,
    shadow_root: Path,
    root: Path,
) -> dict[str, Any]:
    config = workspace_minimal_evidence_config(
        root_config=root_config,
        pid=pid,
        port=port,
        url=url,
        workspace_root=workspace_root,
        shadow_root=shadow_root,
        root=root,
    )
    config["agentCommand"] = str(root / "bin" / "pi-full")
    config["workspaceDir"] = str(workspace_root.parent)
    return config


def ensure_shadow_runtime(
    *,
    root: Path,
    config: dict[str, Any],
    workspace_root: Path,
    shadow_root: Path,
    metadata: dict[str, Any],
) -> None:
    shadow_root.mkdir(parents=True, exist_ok=True)
    (shadow_root / ".cmux").mkdir(parents=True, exist_ok=True)

    for rel in ["evidence.config.yaml", "package.json", "package-lock.json"]:
        source = root / rel
        if source.exists():
            symlink_or_copy(source, shadow_root / rel)

    for rel in ["scripts", "bin", "pi-pkg", "data"]:
        source = root / rel
        if source.exists():
            symlink_or_copy(source, shadow_root / rel)

    # Do NOT symlink 'sources' from root — the shadow runtime needs its own
    # sources/ directory for generated files (e.g., sources/files/*.sql from
    # data refresh). Root sources are legacy/optional (now in examples/tlc/).
    (shadow_root / "sources").mkdir(parents=True, exist_ok=True)

    # Reuse the main runtime's generated Evidence source/cache data when present.
    # Without this, content-only shadows that live outside the Git checkout cannot
    # be bootstrapped by scripts/ensure_evidence_sources.sh and may regenerate
    # expensive datasource manifests on every first preview.
    evidence_cache = root / ".evidence" / "template" / "static" / "data"
    if evidence_cache.exists():
        symlink_or_copy(evidence_cache, shadow_root / ".evidence" / "template" / "static" / "data")

    node_modules = root / "node_modules"
    if node_modules.exists():
        symlink_or_copy(node_modules, shadow_root / "node_modules")

    for rel in ["pages", "queries", "reports"]:
        content_dir = workspace_root / rel
        content_dir.mkdir(parents=True, exist_ok=True)
        runtime_link = shadow_root / rel
        if runtime_link.exists() or runtime_link.is_symlink():
            if runtime_link.is_symlink() and runtime_link.resolve() != content_dir.resolve():
                runtime_link.unlink()
        if not runtime_link.exists():
            symlink_or_copy(content_dir, runtime_link)

    workspace_data = workspace_root / "data"
    if workspace_data.exists():
        symlink_or_copy(workspace_data, shadow_root / "workspace-data")

    # Keep workspace metadata visible to runtime tools from the shadow app.
    workspace_meta = shadow_root / ".cmux" / "workspace.json"
    if workspace_meta.exists() or workspace_meta.is_symlink():
        if workspace_meta.is_symlink():
            workspace_meta.unlink()
    if not workspace_meta.exists():
        symlink_or_copy(workspace_root / ".cmux" / "workspace.json", workspace_meta)

    evidence_config = shadow_evidence_config(
        root_config=config,
        pid=str(metadata.get("projectId") or project_id(root, config)),
        port=int(metadata.get("port") or config.get("port") or DEFAULT_PORT),
        url=str(metadata.get("url") or config.get("url") or ""),
        workspace_root=workspace_root,
        shadow_root=shadow_root,
        root=root,
    )
    write_json(shadow_root / ".cmux" / "evidence.json", evidence_config)


def is_content_workspace(config: dict[str, Any], metadata: dict[str, Any] | None = None) -> bool:
    metadata = metadata or {}
    if str(metadata.get("kind") or "").strip() == "lumen-analysis-workspace":
        return True
    mode = str(metadata.get("workspaceMode") or config.get("workspaceMode") or "").strip()
    has_split_roots = bool(
        metadata.get("workspaceRoot")
        or metadata.get("shadowRuntimeRoot")
        or config.get("workspaceRoot")
        or config.get("shadowRuntimeRoot")
    )
    return mode == CONTENT_WORKSPACE_MODE and has_split_roots


def ensure_content_shadow_runtime(target: Path, config: dict[str, Any], metadata: dict[str, Any]) -> Path:
    if not is_content_workspace(config, metadata):
        return target

    workspace_root = Path(str(metadata.get("workspaceRoot") or target)).expanduser().resolve()
    shadow_root_value = metadata.get("shadowRuntimeRoot") or config.get("shadowRuntimeRoot")
    runtime_root_value = metadata.get("runtimeRoot") or config.get("runtimeRoot")
    if not shadow_root_value:
        raise ValueError("Content-only workspace metadata is missing shadowRuntimeRoot")
    if not runtime_root_value:
        raise ValueError("Content-only workspace metadata is missing runtimeRoot")

    shadow_root = Path(str(shadow_root_value)).expanduser().resolve()
    root = Path(str(runtime_root_value)).expanduser().resolve()
    try:
        root, root_config = load_project(root)
        ensure_shadow_runtime(
            root=root,
            config=root_config,
            workspace_root=workspace_root,
            shadow_root=shadow_root,
            metadata=metadata,
        )
    except (OSError, ValueError) as exc:
        raise ValueError(
            "Shadow runtime is missing or could not be regenerated.\n"
            f"Workspace: {workspace_root}\n"
            f"Runtime: {shadow_root}\n"
            f"Reason: {exc}"
        ) from exc
    return shadow_root


def new_content_analysis(title: str, *, print_layout: bool = False, open_after_create: bool = True) -> int:
    title = title.strip()
    cwd = Path.cwd().resolve()
    root = git_root(cwd)
    if root is None:
        return error("Not inside a Git repository")
    try:
        root, config = load_project(root)
    except ValueError as exc:
        return error(str(exc))
    if cwd != root:
        return error(f"Run `cmux-evidence new` from the main Evidence project root: {root}")
    if not title:
        if not sys.stdin.isatty():
            return error('Usage: cmux-evidence new "analysis name"')
        print("New Evidence analysis workspace")
        title = prompt_line("Analysis title")
        if not title:
            return error("Analysis title is required")

    pid = project_id(root, config)
    workspaces_root = workspace_dir(root, config)
    if str(config.get("workspaceDir") or ".workspaces") == ".workspaces":
        workspaces_root = expand_path(f"~/.local/share/lumen-bi/workspaces/{pid}")
    shadows_root = runtime_dir(root, config)
    registry_file = registry_path(root, config)
    workspaces_root.mkdir(parents=True, exist_ok=True)
    shadows_root.mkdir(parents=True, exist_ok=True)

    slug = unique_slug(slugify(title), root, workspaces_root)
    workspace_root = workspaces_root / slug
    shadow_root = shadows_root / slug
    port = choose_port(
        int(config.get("analysisBasePort", DEFAULT_ANALYSIS_BASE_PORT)),
        workspaces_root,
        extra_used_ports=registry_workspace_ports(registry_file, pid),
    )
    url = f"http://localhost:{port}"
    created_at = now_iso()
    page_rel = Path("pages") / "index.md"
    draft_rel = Path("pages") / "draft.md"
    report_rel = Path("pages") / "report.md"
    intention: dict[str, Any] = {
        "goal": "",
        "questions": [],
        "stakeholders": [],
        "successCriteria": [],
        "dashboardOptions": [],
        "assumptions": [],
        "clarifications": [],
        "openQuestions": [],
    }
    metadata: dict[str, Any] = {
        "kind": "lumen-analysis-workspace",
        "workspaceMode": CONTENT_WORKSPACE_MODE,
        "projectId": pid,
        "title": title,
        "slug": slug,
        "path": str(workspace_root),
        "workspaceRoot": str(workspace_root),
        "shadowRuntimeRoot": str(shadow_root),
        "runtimeRoot": str(root),
        "page": str(page_rel),
        "pages": {"brief": str(page_rel), "draft": str(draft_rel), "report": str(report_rel)},
        "port": port,
        "url": url,
        "status": "draft",
        "intention": intention,
        "createdAt": created_at,
        "updatedAt": created_at,
    }

    try:
        workspace_root.mkdir(parents=True, exist_ok=False)
        write_brief_page(workspace_root / page_rel, title, metadata)
        write_draft_page(workspace_root / draft_rel, title)
        write_report_page(workspace_root / report_rel, title)
        (workspace_root / "queries").mkdir(parents=True, exist_ok=True)
        (workspace_root / "data").mkdir(parents=True, exist_ok=True)
        (workspace_root / "reports").mkdir(parents=True, exist_ok=True)
        write_json(workspace_root / ".cmux" / "workspace.json", metadata)
        workspace_config = workspace_minimal_evidence_config(
            root_config=config, pid=pid, port=port, url=url, workspace_root=workspace_root, shadow_root=shadow_root, root=root
        )
        write_json(workspace_root / ".cmux" / "evidence.json", workspace_config)
        write_pi_context(workspace_root, metadata, workspace_config)
        # Symlink pi-pkg/ subdirectories into the workspace's .pi/ so the Pi agent
        # (running from workspace root) can discover skills, prompts, extensions,
        # themes, and settings from the main project.
        #
        # DESIGN NOTE: Skills, extensions, prompts, and themes are shared across all
        # content workspaces via symlinks to the main project's pi-pkg/. This means
        # updating a skill in pi-pkg/ immediately affects all workspaces. This is
        # intentional — the workspace isolation is for user content (pages, queries,
        # data), not for project-level tooling. If per-workspace isolation is needed
        # in the future, change symlinks to copies.
        #
        # We symlink individual subdirs rather than the whole pi-pkg/ to avoid
        # leaking project-level state like duckdb/ or todos/ into every workspace.
        workspace_pi = workspace_root / ".pi"
        workspace_pi.mkdir(parents=True, exist_ok=True)
        for _sub in ["skills", "prompts", "extensions", "themes"]:
            _src = root / "pi-pkg" / _sub
            _dst = workspace_pi / _sub
            if _src.exists() and not _dst.exists():
                _dst.symlink_to(_src, target_is_directory=True)
        for _file in ["settings.json", "package.json"]:
            _src = root / "pi-pkg" / _file
            _dst = workspace_pi / _file
            if _src.exists() and not _dst.exists():
                _dst.symlink_to(_src)
        write_content_snapshot(workspace_root, workspace_config, "initial")
        ensure_shadow_runtime(root=root, config=config, workspace_root=workspace_root, shadow_root=shadow_root, metadata=metadata)
        upsert_workspace_registry(registry_file=registry_file, project_id_value=pid, project_root=root, workspace=metadata)
    except (OSError, ValueError) as exc:
        return error(f"Failed to create content-only analysis workspace: {exc}")

    print(f"Created analysis workspace: {title}")
    print()
    print(f"Slug:      {slug}")
    print(f"Workspace: {workspace_root}")
    print(f"Preview:   {url}")
    print()
    print("Start here:")
    print("  1. Explore in pages/draft.md")
    print("  2. Keep reusable SQL in queries/")
    print("  3. Move validated findings to pages/report.md")
    print()
    print(f"Open later: {root / 'bin' / 'cmux-evidence'} open {slug}")
    print()
    print("Publish shares pages/report.md and queries/** by default.")
    print("Draft notes, local data, DuckDB scratch files, and runtime files stay private.")
    print()
    if not open_after_create:
        print("CMUX open skipped (--no-open).")
        return 0
    print("Opening CMUX...")
    return open_workspace(workspace_root, print_layout=print_layout)


def new_analysis(title: str, *, print_layout: bool = False, open_after_create: bool = True) -> int:
    title = title.strip()

    cwd = Path.cwd().resolve()
    root_for_mode = git_root(cwd)
    if root_for_mode is not None:
        try:
            _root_for_mode, _config_for_mode = load_project(root_for_mode)
            if workspace_mode(_config_for_mode) == CONTENT_WORKSPACE_MODE:
                return new_content_analysis(title, print_layout=print_layout, open_after_create=open_after_create)
        except ValueError:
            pass

    cwd = Path.cwd().resolve()
    root = git_root(cwd)
    if root is None:
        return error("Not inside a Git repository")

    try:
        root, config = load_project(root)
    except ValueError as exc:
        return error(str(exc))

    if cwd != root:
        return error(f"Run `cmux-evidence new` from the main Evidence project root: {root}")

    if not title:
        if not sys.stdin.isatty():
            return error('Usage: cmux-evidence new "analysis name"')
        print("New Evidence analysis workspace")
        title = prompt_line("Analysis title")
        if not title:
            return error("Analysis title is required")

    intention: dict[str, Any] = {
        "goal": "",
        "questions": [],
        "stakeholders": [],
        "successCriteria": [],
        "dashboardOptions": [],
        "assumptions": [],
        "clarifications": [],
        "openQuestions": [],
    }

    pid = project_id(root, config)
    workspaces_root = workspace_dir(root, config)
    registry_file = registry_path(root, config)
    workspaces_root.mkdir(parents=True, exist_ok=True)

    base_slug = slugify(title)
    slug = unique_slug(base_slug, root, workspaces_root)
    branch = f"analysis/{slug}"
    worktree_path = workspaces_root / slug
    page_rel = Path("pages") / "analysis" / slug / "index.md"
    page_path = worktree_path / page_rel
    draft_rel = Path("pages") / "analysis" / slug / "draft.md"
    draft_path = worktree_path / draft_rel

    try:
        analysis_base_port = int(config.get("analysisBasePort", DEFAULT_ANALYSIS_BASE_PORT))
        port = choose_port(analysis_base_port, workspaces_root)
    except (TypeError, ValueError, RuntimeError) as exc:
        return error(str(exc))

    base_branch = str(config.get("baseBranch") or "main")

    try:
        subprocess.run(
            ["git", "worktree", "add", "-b", branch, str(worktree_path), base_branch],
            cwd=root,
            check=True,
        )
    except subprocess.CalledProcessError as exc:
        return error(f"Failed to create Git worktree for {branch}: exit {exc.returncode}")

    created_at = now_iso()
    url = f"http://localhost:{port}/analysis/{slug}"
    worktree_config = dict(config)
    worktree_config.update(
        {
            "projectId": pid,
            "port": port,
            "agentCommand": "./bin/pi-full",
            "devCommand": f"npm run dev -- --port {port}",
            "url": url,
            "workspaceDir": str(workspaces_root),
            "registryPath": str(registry_file),
        }
    )
    workspace_metadata: dict[str, Any] = {
        "kind": "evidence-analysis",
        "projectId": pid,
        "title": title,
        "slug": slug,
        "branch": branch,
        "path": str(worktree_path),
        "page": str(page_rel),
        "port": port,
        "url": url,
        "status": "draft",
        "intention": intention,
        "createdFrom": base_branch,
        "createdAt": created_at,
        "updatedAt": created_at,
    }

    try:
        write_brief_page(page_path, title, workspace_metadata)
        write_draft_page(draft_path, title)
        for skill_name in [
            "evidence-dashboard",
            "evidence-dashboard-review",
            "evidence-slides",
            "data-discovery",
            "cmux-workspace",
            "cmux-browser",
            "cmux-pi",
            "cmux-diagnostics",
            "ask-user",
        ]:
            copy_project_skill(root, worktree_path, skill_name)
        copy_project_extension(root, worktree_path, "evidence-context.ts")
        copy_project_extension(root, worktree_path, "pi-ask-user")
        copy_project_extension(root, worktree_path, "analysis-intention")
        copy_project_extension(root, worktree_path, "duckdb-bi")
        copy_project_extension(root, worktree_path, "lumen-bi")
        copy_project_subdir(root, worktree_path, str(Path("pi-pkg") / "themes"))
        copy_project_subdir(root, worktree_path, str(Path("pi-pkg") / "settings.json"))
        copy_project_subdir(root, worktree_path, str(Path("pi-pkg") / "package.json"))
        copy_project_subdir(root, worktree_path, str(Path("bin") / "pi-full"))
        (worktree_path / ".cmux").mkdir(parents=True, exist_ok=True)
        (worktree_path / ".cmux" / "evidence.json").write_text(
            json.dumps(worktree_config, indent=2) + "\n"
        )
        (worktree_path / ".cmux" / "workspace.json").write_text(
            json.dumps(workspace_metadata, indent=2) + "\n"
        )
        write_pi_context(worktree_path, workspace_metadata, worktree_config)
        upsert_workspace_registry(
            registry_file=registry_file,
            project_id_value=pid,
            project_root=root,
            workspace=workspace_metadata,
        )
    except (OSError, ValueError) as exc:
        return error(f"Created worktree, but failed to write analysis metadata: {exc}")

    path_display = str(worktree_path)
    try:
        path_display = str(worktree_path.relative_to(root))
    except ValueError:
        pass

    print("Created analysis workspace")
    print()
    print(f"Title:  {title}")
    print(f"Slug:   {slug}")
    print(f"Branch: {branch}")
    print(f"Path:   {path_display}")
    print(f"Page:   {page_rel}")
    print(f"Port:   {port}")
    print(f"URL:    {url}")
    print()
    if not open_after_create:
        print("CMUX open skipped (--no-open).")
        return 0

    print("Opening CMUX...")

    return open_workspace(worktree_path, print_layout=print_layout)


def metadata_is_content_only(metadata: dict[str, Any]) -> bool:
    if str(metadata.get("kind") or "").strip() == "lumen-analysis-workspace":
        return True
    return str(metadata.get("workspaceMode") or "").strip() == CONTENT_WORKSPACE_MODE


def list_analyses() -> int:
    try:
        root, config = load_current_project()
        pid = project_id(root, config)
        registry = load_registry(registry_path(root, config))
    except ValueError as exc:
        return error(str(exc))

    workspaces = registry.get("projects", {}).get(pid, {}).get("workspaces", {})
    if not workspaces:
        print(f"No analysis workspaces found for {pid}.")
        return 0

    rows = sorted(workspaces.values(), key=lambda row: str(row.get("slug", "")))
    print(f"Analyses for {pid}")
    print()
    print(f"{'SLUG':<28} {'STATUS':<10} {'MODE':<13} {'PORT':<5} TITLE")
    for row in rows:
        mode = "content" if metadata_is_content_only(row) else "worktree"
        title = str(row.get("title") or row.get("branch") or "")
        print(
            f"{str(row.get('slug', '')):<28} "
            f"{str(row.get('status', '')):<10} "
            f"{mode:<13} "
            f"{str(row.get('port', '')):<5} "
            f"{title}"
        )
    print()
    print("Open a workspace with: cmux-evidence open <slug>")
    return 0


def load_workspace_metadata(target: Path) -> dict[str, Any] | None:
    path = target / ".cmux" / "workspace.json"
    if not path.exists():
        return None
    try:
        data = json.loads(path.read_text())
    except json.JSONDecodeError as exc:
        raise ValueError(f"Invalid JSON in {path}: {exc}") from exc
    if not isinstance(data, dict):
        raise ValueError(f"Invalid {path}: expected a JSON object")
    return data


def current_workspace_metadata() -> dict[str, Any]:
    cwd = Path.cwd().resolve()
    metadata = load_workspace_metadata(cwd)
    if metadata is not None:
        return metadata

    root = git_root(cwd)
    if root is None:
        raise ValueError("Not inside a Git repository")
    metadata = load_workspace_metadata(root)
    if metadata is not None:
        return metadata

    config_path = root / ".cmux" / "evidence.json"
    if not config_path.exists():
        raise ValueError("No .cmux/workspace.json or .cmux/evidence.json found")
    config = load_config(config_path)
    branch = run_git(root, ["branch", "--show-current"], check=False).stdout.strip()
    port = int(config.get("port", DEFAULT_PORT))
    return {
        "kind": "evidence-project",
        "projectId": project_id(root, config),
        "title": root.name,
        "slug": root.name,
        "branch": branch,
        "path": str(root),
        "page": "",
        "port": port,
        "url": str(config.get("url") or f"http://localhost:{port}"),
        "status": "project",
    }


def print_metadata(metadata: dict[str, Any]) -> None:
    if metadata_is_content_only(metadata):
        pages = metadata.get("pages") if isinstance(metadata.get("pages"), dict) else {}
        fields: list[tuple[str, Any]] = [
            ("Title", metadata.get("title")),
            ("Slug", metadata.get("slug")),
            ("Workspace mode", "content-only"),
            ("Workspace", metadata.get("workspaceRoot") or metadata.get("path")),
            ("Brief", pages.get("brief") or metadata.get("page")),
            ("Draft", pages.get("draft")),
            ("Report", pages.get("report")),
            ("Preview", metadata.get("url")),
            ("Port", metadata.get("port")),
            ("Status", metadata.get("status")),
        ]
        for label, value in fields:
            if value not in (None, ""):
                print(f"{label}: {value}")
        return

    fields = ["title", "slug", "branch", "page", "port", "url", "status"]
    for field in fields:
        value = metadata.get(field)
        if value not in (None, ""):
            label = "URL" if field == "url" else field.title()
            print(f"{label}: {value}")


def current_command() -> int:
    try:
        print_metadata(current_workspace_metadata())
    except (TypeError, ValueError) as exc:
        return error(str(exc))
    return 0


def resolve_preview_url() -> str:
    metadata = current_workspace_metadata()
    url = str(metadata.get("url") or "").strip()
    if url:
        return url
    port = metadata.get("port")
    if port not in (None, ""):
        return f"http://localhost:{int(port)}"
    target = current_workspace_root()
    config = load_config(target / ".cmux" / "evidence.json")
    url = str(config.get("url") or "").strip()
    if url:
        return url
    port = config.get("port")
    if port not in (None, ""):
        return f"http://localhost:{int(port)}"
    raise ValueError("Could not resolve Evidence preview URL from .cmux/workspace.json or .cmux/evidence.json")


def preview_url_command() -> int:
    try:
        print(resolve_preview_url())
    except (TypeError, ValueError) as exc:
        return error(str(exc))
    return 0


def cmux_workspace_id() -> str | None:
    return os.environ.get("CMUX_WORKSPACE_ID")


def cmux_binary() -> str | None:
    return shutil.which("cmux")


def run_cmux(args: list[str]) -> subprocess.CompletedProcess[str]:
    cmux = cmux_binary()
    if not cmux:
        raise ValueError("Could not find cmux binary")
    return subprocess.run(
        [cmux, *args],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def current_workspace_root() -> Path:
    cwd = Path.cwd().resolve()
    if (cwd / ".cmux" / "evidence.json").exists():
        return cwd
    root = git_root(cwd)
    if root is None:
        raise ValueError("Not inside a Git repository")
    if not (root / ".cmux" / "evidence.json").exists():
        raise ValueError(f"Not an Evidence CMUX workspace: {root}")
    return root


def context_command(*, print_context: bool = False) -> int:
    try:
        target = current_workspace_root()
        config = load_config(target / ".cmux" / "evidence.json")
        metadata = load_workspace_metadata(target)
        if metadata is None:
            metadata = current_workspace_metadata()
        content = render_pi_context(
            project_id_value=str(metadata.get("projectId") or project_id(target, config)),
            title=str(metadata.get("title") or target.name),
            slug=str(metadata.get("slug") or target.name),
            branch=str(metadata.get("branch") or ""),
            worktree_path=Path(str(metadata.get("path") or target)).expanduser().resolve(),
            page=str(metadata.get("page") or ""),
            port=int(metadata.get("port") or config.get("port") or DEFAULT_PORT),
            url=str(metadata.get("url") or config.get("url") or ""),
            config=config,
            metadata=metadata,
        )
    except (TypeError, ValueError) as exc:
        return error(str(exc))

    if print_context:
        print(content, end="")
        return 0

    context_path = target / ".cmux" / "pi-context.md"
    try:
        context_path.write_text(content)
    except OSError as exc:
        return error(f"Failed to write {context_path}: {exc}")
    print(context_path)
    return 0


def url_port_reachable(url: str) -> bool:
    parsed = urllib.parse.urlparse(url)
    host = parsed.hostname or "localhost"
    port = parsed.port or (443 if parsed.scheme == "https" else 80)
    try:
        with socket.create_connection((host, port), timeout=0.5):
            return True
    except OSError:
        return False


def status_command() -> int:
    try:
        metadata = current_workspace_metadata()
    except (TypeError, ValueError) as exc:
        return error(str(exc))

    print_metadata(metadata)
    print()
    if metadata_is_content_only(metadata):
        print("Workspace storage: local content workspace")
        print("Git checkout: not used for this workspace mode")
    else:
        print("Git status:")
        root = git_root(Path.cwd().resolve())
        if root is None:
            print("not a Git checkout")
        else:
            result = run_git(root, ["status", "--short"], check=False)
            print(result.stdout.rstrip() or "clean")
    print()
    url = str(metadata.get("url") or "")
    if url:
        reachable = url_port_reachable(url)
        if reachable:
            print(f"Preview server: reachable ({url})")
        else:
            slug = str(metadata.get("slug") or "<slug>")
            print(f"Preview server: not running yet ({url})")
            print(f"Open with: cmux-evidence open {slug}")
    else:
        print("Preview server: unknown")
    return 0


def find_browser_surfaces(value: Any) -> list[dict[str, Any]]:
    browsers: list[dict[str, Any]] = []

    def visit(item: Any) -> None:
        if isinstance(item, dict):
            item_type = str(item.get("type") or item.get("surfaceType") or item.get("kind") or "").lower()
            if item_type == "browser":
                browsers.append(item)
            for child in item.values():
                visit(child)
        elif isinstance(item, list):
            for child in item:
                visit(child)

    visit(value)
    return browsers


def surface_ref(surface: dict[str, Any]) -> str | None:
    for key in ("ref", "surface", "id", "surfaceId"):
        value = surface.get(key)
        if isinstance(value, str) and value:
            return value
    return None


def surface_url(surface: dict[str, Any]) -> str:
    for key in ("url", "currentUrl", "href"):
        value = surface.get(key)
        if isinstance(value, str):
            return value
    return ""


def list_browser_surfaces() -> tuple[list[dict[str, Any]], str]:
    workspace = cmux_workspace_id()
    if not workspace:
        raise ValueError("CMUX_WORKSPACE_ID is not set; run this inside a CMUX workspace")

    panes_completed = run_cmux(["list-panes", "--workspace", workspace, "--json"])
    panes_output = panes_completed.stdout.strip()
    if panes_completed.returncode != 0:
        raise ValueError((panes_completed.stderr or panes_output or "cmux list-panes failed").strip())

    try:
        panes_data = json.loads(panes_output)
    except json.JSONDecodeError:
        completed = run_cmux(["list-pane-surfaces", "--workspace", workspace, "--json"])
        output = completed.stdout.strip()
        if completed.returncode != 0:
            raise ValueError((completed.stderr or output or "cmux list-pane-surfaces failed").strip())
        return [], output

    pane_refs = [pane.get("ref") for pane in panes_data.get("panes", []) if isinstance(pane, dict)]
    all_browser_surfaces: list[dict[str, Any]] = []
    all_outputs: list[dict[str, Any]] = []
    for pane_ref in pane_refs:
        if not isinstance(pane_ref, str) or not pane_ref:
            continue
        completed = run_cmux(
            ["list-pane-surfaces", "--workspace", workspace, "--pane", pane_ref, "--json"]
        )
        output = completed.stdout.strip()
        if completed.returncode != 0:
            continue
        try:
            pane_data = json.loads(output)
        except json.JSONDecodeError:
            continue
        all_outputs.append(pane_data)
        for surface in find_browser_surfaces(pane_data):
            ref = surface_ref(surface)
            if ref and not surface_url(surface):
                url_completed = run_cmux(["browser", ref, "get", "url"])
                if url_completed.returncode == 0 and url_completed.stdout.strip():
                    surface["url"] = url_completed.stdout.strip()
            all_browser_surfaces.append(surface)

    return all_browser_surfaces, json.dumps(all_outputs, indent=2)


def browser_surfaces_command() -> int:
    try:
        browsers, raw = list_browser_surfaces()
    except ValueError as exc:
        return error(str(exc))
    if browsers:
        print(json.dumps(browsers, indent=2))
    else:
        print(raw or "No browser surfaces found.")
    return 0


def preview_open_command() -> int:
    try:
        url = resolve_preview_url()
    except (TypeError, ValueError) as exc:
        return error(str(exc))

    workspace = cmux_workspace_id()
    if not workspace:
        print(url)
        print("CMUX_WORKSPACE_ID is not set; open this URL in a browser pane from CMUX.", file=sys.stderr)
        return 0

    try:
        completed = run_cmux(
            [
                "new-pane",
                "--workspace",
                workspace,
                "--type",
                "browser",
                "--direction",
                "right",
                "--url",
                url,
                "--focus",
                "false",
            ]
        )
    except ValueError as exc:
        return error(str(exc))

    if completed.stdout:
        print(completed.stdout, end="")
    if completed.stderr:
        print(completed.stderr, end="", file=sys.stderr)
    return completed.returncode


def choose_browser_surface() -> str:
    browsers, _raw = list_browser_surfaces()
    if not browsers:
        raise ValueError("No browser surfaces found. Run `cmux-evidence preview-open` first.")

    url = resolve_preview_url().rstrip("/")
    matching = [surface for surface in browsers if surface_url(surface).rstrip("/") == url]
    if len(matching) == 1:
        ref = surface_ref(matching[0])
        if ref:
            return ref
    if len(browsers) == 1:
        ref = surface_ref(browsers[0])
        if ref:
            return ref

    choices = []
    for surface in browsers:
        ref = surface_ref(surface) or "<unknown>"
        choices.append(f"- {ref} {surface_url(surface)}".rstrip())
    raise ValueError(
        "Multiple browser surfaces found. Pass a surface ref explicitly:\n" + "\n".join(choices)
    )


def surface_arg_or_auto(args: list[str]) -> str:
    if args:
        return args[0]
    return choose_browser_surface()


def print_cmux_result(completed: subprocess.CompletedProcess[str]) -> int:
    if completed.stdout:
        print(completed.stdout, end="")
    if completed.stderr:
        print(completed.stderr, end="", file=sys.stderr)
    return completed.returncode


def preview_title_command(args: list[str]) -> int:
    try:
        surface = surface_arg_or_auto(args)
        completed = run_cmux(["browser", surface, "eval", "document.title"])
    except ValueError as exc:
        return error(str(exc))
    return print_cmux_result(completed)


def preview_snapshot_command(args: list[str]) -> int:
    try:
        surface = surface_arg_or_auto(args)
        completed = run_cmux(["browser", surface, "snapshot", "--interactive"])
    except ValueError as exc:
        return error(str(exc))
    return print_cmux_result(completed)


def preview_screenshot_command(args: list[str]) -> int:
    try:
        surface = surface_arg_or_auto(args)
        if len(args) > 1:
            path = Path(args[1]).expanduser().resolve()
        else:
            slug = str(current_workspace_metadata().get("slug") or "preview")
            path = Path(f"/tmp/cmux-evidence-preview-{slug}.png")
        completed = run_cmux(["browser", surface, "screenshot", "--out", str(path)])
    except (TypeError, ValueError) as exc:
        return error(str(exc))
    if completed.returncode == 0:
        print(path)
    return print_cmux_result(completed)


def cmux_best_effort(args: list[str]) -> None:
    if not cmux_workspace_id() or not cmux_binary():
        return
    subprocess.run([cmux_binary() or "cmux", *args], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)


def package_has_script(target: Path, script_name: str) -> bool:
    package_json = target / "package.json"
    if not package_json.exists():
        return False
    try:
        package = json.loads(package_json.read_text())
    except json.JSONDecodeError:
        return False
    scripts = package.get("scripts")
    return isinstance(scripts, dict) and script_name in scripts


def validation_command(target: Path, config: dict[str, Any]) -> str | None:
    configured = str(config.get("validateCommand") or "").strip()
    if configured:
        return configured
    if package_has_script(target, "build"):
        return "npm run build"
    if package_has_script(target, "sources"):
        return "npm run sources"
    return None


def workspace_target_config_metadata() -> tuple[Path, dict[str, Any], dict[str, Any]]:
    target = current_workspace_root()
    config = load_config(target / ".cmux" / "evidence.json")
    metadata = load_workspace_metadata(target) or current_workspace_metadata()
    return target, config, metadata


def validate_command() -> int:
    try:
        target, config, metadata = workspace_target_config_metadata()
        repaired_shadow_root = ensure_content_shadow_runtime(target, config, metadata)
        validation_target = repaired_shadow_root if is_content_workspace(config, metadata) else Path(str(metadata.get("shadowRuntimeRoot") or target)).expanduser().resolve()
        command = validation_command(validation_target, config)
    except (TypeError, ValueError) as exc:
        return error(str(exc))

    print_metadata(metadata)
    print()
    if not command:
        return error("No validation command configured. Add validateCommand to .cmux/evidence.json or define npm script 'build'.")

    print(f"Running validation: {command}")
    print()
    sys.stdout.flush()
    workspace = cmux_workspace_id()
    if workspace:
        cmux_best_effort(["set-status", "validation", "running", "--workspace", workspace, "--color", "#ff9500"])
        cmux_best_effort(["set-progress", "0.2", "--label", "Validating", "--workspace", workspace])

    try:
        completed = subprocess.run(command, cwd=validation_target, shell=True)
    except OSError as exc:
        return error(
            "Validation could not start.\n"
            f"Workspace: {target}\n"
            f"Runtime: {validation_target}\n"
            f"Reason: {exc}"
        )

    if workspace:
        if completed.returncode == 0:
            cmux_best_effort(["set-status", "validation", "passed", "--workspace", workspace, "--color", "#34c759"])
            cmux_best_effort(["clear-progress", "--workspace", workspace])
        else:
            cmux_best_effort(["set-status", "validation", "failed", "--workspace", workspace, "--color", "#ff3b30"])
            cmux_best_effort(["notify", "--title", "Evidence Validation", "--body", "Validation failed", "--workspace", workspace])

    return completed.returncode


def diff_command(*, stat_only: bool = False) -> int:
    try:
        target, config, metadata = workspace_target_config_metadata()
    except (TypeError, ValueError) as exc:
        return error(str(exc))

    print_metadata(metadata)
    print()

    if is_content_workspace(config, metadata):
        baseline_root = content_baseline_root(target)
        baseline = read_deliverable_tree(baseline_root, config) if baseline_root else {}
        current = read_deliverable_tree(target, config)
        label = "last published snapshot" if baseline_root and baseline_root.name == "last-published" else "initial snapshot"
        if baseline_root is None:
            print("No content snapshot found; showing all publishable files as new.")
        else:
            print(f"Comparing publishable content against {label}.")
        print("Publishable by default: pages/report.md and queries/**")
        if config.get("publishReports"):
            print("Also included by config: reports/**")
        if config.get("publishData"):
            print("Also included by config: data/**")
        else:
            data_files = [p for p in (target / "data").rglob("*") if p.is_file()] if (target / "data").exists() else []
            if data_files:
                print("Local data files are private by default and are not included in this diff.")
        print()
        rendered, _changed = render_content_diff(baseline=baseline, current=current, stat_only=stat_only)
        print(rendered, end="")
        return 0

    commands = [["status", "--short"], ["diff", "--stat"]]
    if not stat_only:
        commands.append(["diff"])

    exit_code = 0
    for git_args in commands:
        print(f"$ git {' '.join(git_args)}")
        result = run_git(target, git_args, check=False)
        if result.stdout:
            print(result.stdout, end="")
        if result.stderr:
            print(result.stderr, end="", file=sys.stderr)
        if not result.stdout and result.returncode == 0 and git_args == ["status", "--short"]:
            print("clean")
        if result.returncode != 0:
            exit_code = result.returncode
        print()
    return exit_code


def ensure_analysis_workspace(metadata: dict[str, Any]) -> None:
    if metadata.get("kind") != "evidence-analysis" or not metadata.get("slug"):
        raise ValueError("Publish must be run inside a generated Evidence analysis worktree")


def git_changed_paths(target: Path) -> list[str]:
    result = run_git(target, ["status", "--porcelain", "-z"], check=False)
    if result.returncode != 0:
        raise ValueError((result.stderr or "git status failed").strip())
    entries = result.stdout.split("\0")
    paths: list[str] = []
    for entry in entries:
        if not entry:
            continue
        path_text = entry[3:] if len(entry) > 3 else entry
        if " -> " in path_text:
            path_text = path_text.split(" -> ", 1)[1]
        paths.append(path_text)
    return paths


def path_matches_any(path: str, patterns: list[str]) -> bool:
    return any(fnmatch.fnmatch(path, pattern) for pattern in patterns)


def should_include_content_path(rel: str, config: dict[str, Any]) -> bool:
    rel = rel.replace(os.sep, "/")
    include_reports = bool(config.get("publishReports"))
    include_data = bool(config.get("publishData"))

    if rel == "pages/report.md" or rel.startswith("queries/"):
        return True
    if include_reports and rel.startswith("reports/"):
        return True
    if include_data and rel.startswith("data/"):
        return True
    return False


def iter_content_deliverable_files(workspace_root: Path, config: dict[str, Any]) -> list[Path]:
    files: list[Path] = []
    for top in ["pages", "queries", "reports", "data"]:
        root = workspace_root / top
        if not root.exists():
            continue
        for path in sorted(root.rglob("*")):
            if not path.is_file():
                continue
            rel = path.relative_to(workspace_root).as_posix()
            if should_include_content_path(rel, config):
                files.append(path)
    return files


def read_deliverable_tree(root: Path, config: dict[str, Any]) -> dict[str, bytes]:
    files: dict[str, bytes] = {}
    for path in iter_content_deliverable_files(root, config):
        rel = path.relative_to(root).as_posix()
        try:
            files[rel] = path.read_bytes()
        except OSError:
            continue
    return files


def write_deliverable_tree(source_root: Path, target_root: Path, config: dict[str, Any]) -> None:
    if target_root.exists():
        shutil.rmtree(target_root)
    target_root.mkdir(parents=True, exist_ok=True)
    for source in iter_content_deliverable_files(source_root, config):
        rel = source.relative_to(source_root)
        target = target_root / rel
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, target)


def content_snapshot_root(workspace_root: Path, name: str) -> Path:
    return workspace_root / ".cmux" / "snapshots" / name


def content_baseline_root(workspace_root: Path) -> Path | None:
    published = content_snapshot_root(workspace_root, "last-published")
    if published.exists():
        return published
    initial = content_snapshot_root(workspace_root, "initial")
    if initial.exists():
        return initial
    return None


def write_content_snapshot(workspace_root: Path, config: dict[str, Any], name: str) -> Path:
    path = content_snapshot_root(workspace_root, name)
    write_deliverable_tree(workspace_root, path, config)
    return path


def bytes_are_text(value: bytes) -> bool:
    if b"\0" in value:
        return False
    try:
        value.decode("utf-8")
        return True
    except UnicodeDecodeError:
        return False


def short_hash(value: bytes) -> str:
    return hashlib.sha256(value).hexdigest()[:12]


def render_content_diff(
    *,
    baseline: dict[str, bytes],
    current: dict[str, bytes],
    stat_only: bool = False,
) -> tuple[str, bool]:
    paths = sorted(set(baseline) | set(current))
    changed = False
    lines: list[str] = []
    for rel in paths:
        before = baseline.get(rel)
        after = current.get(rel)
        if before == after:
            continue
        changed = True
        if before is None:
            lines.append(f"A  {rel}")
        elif after is None:
            lines.append(f"D  {rel}")
        else:
            lines.append(f"M  {rel}")
    if not changed:
        return "clean\n", False
    if stat_only:
        return "\n".join(lines) + "\n", True

    detail: list[str] = [*lines, ""]
    for rel in paths:
        before = baseline.get(rel)
        after = current.get(rel)
        if before == after:
            continue
        if before is None:
            before = b""
        if after is None:
            after = b""
        if not bytes_are_text(before) or not bytes_are_text(after):
            detail.append(f"Binary files differ: {rel} ({short_hash(before)} -> {short_hash(after)})")
            detail.append("")
            continue
        before_lines = before.decode("utf-8").splitlines(keepends=True)
        after_lines = after.decode("utf-8").splitlines(keepends=True)
        detail.extend(
            difflib.unified_diff(
                before_lines,
                after_lines,
                fromfile=f"baseline/{rel}",
                tofile=f"current/{rel}",
            )
        )
        if detail and detail[-1].strip():
            detail.append("\n")
    return "".join(line if line.endswith("\n") else f"{line}\n" for line in detail), True


def content_publish_worktree_root(runtime: Path, slug: str) -> Path:
    return runtime / ".cmux" / "publish-worktrees" / slug


def materialize_content_for_publish(workspace_root: Path, publish_root: Path, metadata: dict[str, Any], config: dict[str, Any]) -> list[str]:
    slug = str(metadata.get("slug") or workspace_root.name)
    written: list[str] = []

    report = workspace_root / "pages" / "report.md"
    if report.exists():
        target = publish_root / "pages" / "reports" / slug / "index.md"
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(report, target)
        written.append(target.relative_to(publish_root).as_posix())

    queries = workspace_root / "queries"
    if queries.exists():
        target_queries = publish_root / "queries" / slug
        if target_queries.exists():
            shutil.rmtree(target_queries)
        for source in sorted(queries.rglob("*")):
            if source.is_file():
                target = target_queries / source.relative_to(queries)
                target.parent.mkdir(parents=True, exist_ok=True)
                shutil.copy2(source, target)
                written.append(target.relative_to(publish_root).as_posix())

    if config.get("publishReports"):
        reports = workspace_root / "reports"
        if reports.exists():
            target_reports = publish_root / "reports" / slug
            if target_reports.exists():
                shutil.rmtree(target_reports)
            for source in sorted(reports.rglob("*")):
                if source.is_file():
                    target = target_reports / source.relative_to(reports)
                    target.parent.mkdir(parents=True, exist_ok=True)
                    shutil.copy2(source, target)
                    written.append(target.relative_to(publish_root).as_posix())

    return written


def ensure_no_blocked_changes(target: Path, config: dict[str, Any]) -> None:
    blocked = string_list_config(config, "blockedAgentPaths", [".env*", "**/connection.yaml", ".github/**"])
    blocked_changes = [path for path in git_changed_paths(target) if path_matches_any(path, blocked)]
    if blocked_changes:
        raise ValueError("Refusing to publish blocked paths:\n" + "\n".join(f"- {path}" for path in blocked_changes))


def write_pr_body(target: Path, metadata: dict[str, Any]) -> Path:
    path = target / ".cmux" / "pr-body.md"
    title = str(metadata.get("title") or "Evidence analysis")
    path.write_text(
        f"""# Evidence analysis

## Summary

Adds the {title} analysis dashboard.

## Workspace metadata

- Branch: {metadata.get('branch', '')}
- Page: {metadata.get('page', '')}
- Local preview: {metadata.get('url', '')}

## Validation

- [x] `cmux-evidence validate` passed locally
- [ ] Dashboard preview reviewed
- [x] Diff reviewed

## Notes

Generated from a CMUX Evidence analysis workspace.
"""
    )
    return path


def update_workspace_status(target: Path, config: dict[str, Any], metadata: dict[str, Any], status: str) -> None:
    metadata["status"] = status
    metadata["updatedAt"] = now_iso()
    (target / ".cmux" / "workspace.json").write_text(json.dumps(metadata, indent=2) + "\n")
    registry_file = registry_path(target, config)
    pid = str(metadata.get("projectId") or project_id(target, config))
    project_root = target
    try:
        registry = load_registry(registry_file)
        existing_root = registry.get("projects", {}).get(pid, {}).get("root")
        if existing_root:
            project_root = Path(str(existing_root)).expanduser().resolve()
    except ValueError:
        project_root = target
    upsert_workspace_registry(
        registry_file=registry_file,
        project_id_value=pid,
        project_root=project_root,
        workspace=metadata,
    )


def confirm_publish(metadata: dict[str, Any]) -> bool:
    print("Publish this analysis branch?")
    print()
    print(f"Title:  {metadata.get('title', '')}")
    print(f"Branch: {metadata.get('branch', '')}")
    print(f"Page:   {metadata.get('page', '')}")
    print()
    print("Type 'publish' to continue: ", end="", flush=True)
    return sys.stdin.readline().strip() == "publish"


def confirm_content_publish(metadata: dict[str, Any]) -> bool:
    slug = str(metadata.get("slug") or "")
    print("Publish this report for review?")
    print()
    print(f"Title:  {metadata.get('title', '')}")
    print(f"Report: pages/report.md")
    print(f"Route:  /reports/{slug}/")
    print()
    print("This publishes the polished report and queries/**. Draft notes and local data stay private by default.")
    print("Type 'publish' to continue: ", end="", flush=True)
    return sys.stdin.readline().strip() == "publish"


def publish_content_workspace(target: Path, config: dict[str, Any], metadata: dict[str, Any]) -> int:
    workspace_root = Path(str(metadata.get("workspaceRoot") or target)).expanduser().resolve()
    runtime_value = metadata.get("runtimeRoot") or config.get("runtimeRoot")
    if not runtime_value:
        return error("Content-only workspace metadata is missing runtimeRoot")
    runtime = Path(str(runtime_value)).expanduser().resolve()
    slug = str(metadata.get("slug") or workspace_root.name)
    branch = f"analysis/{slug}"
    base_branch = str(config.get("baseBranch") or "main")
    publish_root = content_publish_worktree_root(runtime, slug)

    validation_result = validate_command()
    if validation_result != 0:
        return validation_result

    diff_command(stat_only=True)
    if not confirm_content_publish(metadata):
        print("Publish cancelled.")
        return 1

    data_files = [p for p in (workspace_root / "data").rglob("*") if p.is_file()] if (workspace_root / "data").exists() else []
    if data_files and not config.get("publishData"):
        print()
        print("Note: local data files were not published. They are private by default:")
        for path in data_files[:20]:
            print(f"- {path.relative_to(workspace_root).as_posix()}")
        if len(data_files) > 20:
            print(f"- ... {len(data_files) - 20} more")

    try:
        project_root, _runtime_config = load_project(runtime)
    except ValueError as exc:
        return error(str(exc))

    if git_root(project_root) is None:
        return error(
            f"Publish requires a Git repository at the project root.\n"
            f"Project root: {project_root}\n"
            f"Run 'git init' in the project root and try again."
        )

    if publish_root.exists() and not (publish_root / ".git").exists():
        shutil.rmtree(publish_root)
    if not publish_root.exists():
        result = run_git(project_root, ["worktree", "add", "-B", branch, str(publish_root), base_branch], check=False)
    else:
        result = run_git(publish_root, ["checkout", "-B", branch], check=False)
    if result.returncode != 0:
        return error(
            f"Failed to prepare publish worktree.\n"
            f"Project root: {project_root}\n"
            f"Branch: {branch}\n"
            f"Git output: {(result.stderr or result.stdout or '').strip()}"
        )

    target_report_dir = publish_root / "pages" / "reports" / slug
    target_queries_dir = publish_root / "queries" / slug
    target_reports_dir = publish_root / "reports" / slug
    for path in [target_report_dir, target_queries_dir, target_reports_dir]:
        if path.exists():
            shutil.rmtree(path)

    written = materialize_content_for_publish(workspace_root, publish_root, metadata, config)
    if not written:
        return error("No publishable content found. Add a polished report to pages/report.md or reusable SQL under queries/.")

    print()
    print("Materialized publish files:")
    for rel in written:
        print(f"- {rel}")

    changed = git_changed_paths(publish_root)
    if not changed:
        print("No publish changes after materialization.")
        write_content_snapshot(workspace_root, config, "last-published")
        try:
            update_workspace_status(workspace_root, config, metadata, "published")
        except (OSError, ValueError) as exc:
            print(f"Warning: failed to update workspace metadata: {exc}", file=sys.stderr)
        return 0

    message = f"Publish report: {metadata.get('title') or slug}"
    run_git(publish_root, ["add", "-A"], check=False)
    commit = run_git(publish_root, ["commit", "-m", message], check=False)
    if commit.stdout:
        print(commit.stdout, end="")
    if commit.stderr:
        print(commit.stderr, end="", file=sys.stderr)
    if commit.returncode != 0:
        return commit.returncode

    try:
        update_workspace_status(workspace_root, config, metadata, "published")
        write_content_snapshot(workspace_root, config, "last-published")
    except (OSError, ValueError) as exc:
        print(f"Warning: failed to update workspace metadata: {exc}", file=sys.stderr)

    push = run_git(publish_root, ["push", "-u", "origin", branch], check=False)
    if push.stdout:
        print(push.stdout, end="")
    if push.stderr:
        print(push.stderr, end="", file=sys.stderr)
    if push.returncode != 0:
        print()
        print("Push failed or no remote is configured. Your publish commit is ready locally:")
        print(f"Worktree: {publish_root}")
        print(f"Branch:   {branch}")
        print(f"Manual push: git -C {publish_root} push -u origin {branch}")
        return 0

    gh = shutil.which("gh")
    if not gh:
        print()
        print("gh CLI not found. Open a PR manually from this branch:")
        print(f"git -C {publish_root} push -u origin {branch}")
        return 0

    body_path = write_pr_body(publish_root, {**metadata, "branch": branch, "page": f"pages/reports/{slug}/index.md"})
    pr = subprocess.run(
        [gh, "pr", "create", "--title", message, "--body-file", str(body_path)],
        cwd=publish_root,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if pr.stdout:
        print(pr.stdout, end="")
    if pr.stderr:
        print(pr.stderr, end="", file=sys.stderr)
    if pr.returncode == 0:
        try:
            update_workspace_status(workspace_root, config, metadata, "pr-opened")
        except (OSError, ValueError) as exc:
            print(f"Warning: failed to update workspace metadata: {exc}", file=sys.stderr)
    return 0


def publish_command() -> int:
    try:
        target, config, metadata = workspace_target_config_metadata()
        if is_content_workspace(config, metadata):
            return publish_content_workspace(target, config, metadata)
        ensure_analysis_workspace(metadata)
        ensure_no_blocked_changes(target, config)
    except (TypeError, ValueError) as exc:
        return error(str(exc))

    workspace = cmux_workspace_id()
    if workspace:
        cmux_best_effort(["set-progress", "0.2", "--label", "Validating", "--workspace", workspace])

    validation_result = validate_command()
    if validation_result != 0:
        return validation_result

    if not git_changed_paths(target):
        print("No changes to publish.")
        return 0

    diff_command(stat_only=True)
    if not confirm_publish(metadata):
        print("Publish cancelled.")
        return 1

    title = str(metadata.get("title") or metadata.get("slug") or "Evidence analysis")
    branch = str(metadata.get("branch") or run_git(target, ["branch", "--show-current"], check=False).stdout.strip())
    message = f"Add analysis: {title}"

    if workspace:
        cmux_best_effort(["set-progress", "0.6", "--label", "Committing", "--workspace", workspace])

    run_git(target, ["add", "-A"], check=False)
    commit = run_git(target, ["commit", "-m", message], check=False)
    if commit.stdout:
        print(commit.stdout, end="")
    if commit.stderr:
        print(commit.stderr, end="", file=sys.stderr)
    if commit.returncode != 0:
        return commit.returncode

    try:
        update_workspace_status(target, config, metadata, "committed")
    except (OSError, ValueError) as exc:
        print(f"Warning: failed to update workspace metadata: {exc}", file=sys.stderr)

    push = run_git(target, ["push", "-u", "origin", branch], check=False)
    if push.stdout:
        print(push.stdout, end="")
    if push.stderr:
        print(push.stderr, end="", file=sys.stderr)
    if push.returncode != 0:
        print()
        print("Push failed. Run manually when ready:")
        print(f"git push -u origin {branch}")
        return push.returncode

    try:
        update_workspace_status(target, config, metadata, "published")
    except (OSError, ValueError) as exc:
        print(f"Warning: failed to update workspace metadata: {exc}", file=sys.stderr)

    gh = shutil.which("gh")
    if not gh:
        print()
        print("gh CLI not found. Open a PR manually from this branch:")
        print(f"git push -u origin {branch}")
        print("# then open a PR from the branch")
        return 0

    if workspace:
        cmux_best_effort(["set-progress", "0.9", "--label", "Opening PR", "--workspace", workspace])

    body_path = write_pr_body(target, metadata)
    pr = subprocess.run(
        [gh, "pr", "create", "--title", message, "--body-file", str(body_path)],
        cwd=target,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if pr.stdout:
        print(pr.stdout, end="")
    if pr.stderr:
        print(pr.stderr, end="", file=sys.stderr)
    if pr.returncode != 0:
        print()
        print("PR creation failed. Open a PR manually from this branch.")
        return 0

    try:
        update_workspace_status(target, config, metadata, "pr-opened")
    except (OSError, ValueError) as exc:
        print(f"Warning: failed to update workspace metadata: {exc}", file=sys.stderr)
    if workspace:
        cmux_best_effort(["notify", "--title", "Evidence Publish", "--body", "PR is ready", "--workspace", workspace])
        cmux_best_effort(["clear-progress", "--workspace", workspace])
    return 0


def usage() -> str:
    return """Usage:
  cmux-evidence [--print-layout] [path]
  cmux-evidence open [--print-layout] [path-or-slug]
  cmux-evidence new [--print-layout] [--no-open] ["analysis name"]
  cmux-evidence list
  cmux-evidence current
  cmux-evidence status
  cmux-evidence context [--print]
  cmux-evidence preview-url
  cmux-evidence preview-open
  cmux-evidence browser-surfaces
  cmux-evidence preview-title [surface-ref]
  cmux-evidence preview-snapshot [surface-ref]
  cmux-evidence preview-screenshot [surface-ref] [path]
  cmux-evidence validate
  cmux-evidence diff
  cmux-evidence publish
""".rstrip()


# ---------------------------------------------------------------------------
# data subcommands
# ---------------------------------------------------------------------------

def data_command(args: list[str]) -> int:
    """Dispatch for 'cmux-evidence data ...' subcommands."""
    sub = args[0] if args else ""
    rest = args[1:] if len(args) > 1 else []
    # Extract optional workspace slug (last arg if it doesn't start with -)
    slug = None
    if rest and not rest[-1].startswith("-"):
        slug = rest[-1]
    if sub == "list":
        return data_list_command(slug)
    if sub == "refresh":
        return data_refresh_command(slug)
    print(
        "Usage: cmux-evidence data <subcommand> [workspace-slug]\n"
        "\n"
        "Subcommands:\n"
        "  list      Show registered workspace data tables\n"
        "  refresh   Scan data files, update registry, generate source SQL\n"
        "\n"
        "If called from inside a workspace, the workspace is auto-detected.\n"
        "If called from the project root, pass the workspace slug as the last argument.\n"
        "Example:\n"
        "  cmux-evidence data refresh my-analysis\n"
    )
    return 1


def _resolve_workspace_root_for_data(slug: str | None = None) -> Path:
    """Resolve workspace root for data commands.

    Works from: content workspace root, or main project root with a slug.
    """
    cwd = Path.cwd().resolve()

    # If a slug is provided, resolve from project root (skip cwd check)
    if slug:
        git_r = git_root(cwd)
        if git_r:
            try:
                root, config = load_project(git_r)
                candidates = []
                workspaces_root = workspace_dir(root, config)
                candidates.append(workspaces_root / slug)
                configured_dir = str(config.get("workspaceDir", ""))
                if configured_dir:
                    expanded = Path(os.path.expanduser(configured_dir))
                    if not expanded.is_absolute():
                        expanded = root / expanded
                    candidates.append(expanded / slug)
                pid = project_id(root, config)
                well_known = Path(f"~/.local/share/lumen-bi/workspaces/{pid}/{slug}").expanduser()
                candidates.append(well_known)
                for candidate in candidates:
                    if candidate.is_dir() and (candidate / ".cmux" / "evidence.json").exists():
                        return candidate
            except (ValueError, OSError):
                pass
        return cwd  # fallback

    # No slug: detect content workspace from cwd
    # Must have BOTH .cmux/evidence.json AND .cmux/workspace.json
    if (cwd / ".cmux" / "evidence.json").exists() and (cwd / ".cmux" / "workspace.json").exists():
        try:
            config = load_config(cwd / ".cmux" / "evidence.json")
            metadata = load_workspace_metadata(cwd) or {}
            if is_content_workspace(config, metadata):
                workspace_root = Path(str(metadata.get("workspaceRoot") or cwd)).expanduser().resolve()
                return workspace_root
        except (ValueError, OSError):
            pass

    # Fallback: use cwd
    return cwd


def data_list_command(slug: str | None = None) -> int:
    """Show registered workspace data tables."""
    try:
        workspace_root = _resolve_workspace_root_for_data(slug)
    except (TypeError, ValueError) as exc:
        return error(str(exc))

    registry = wdr.load_data_registry(workspace_root)
    tables = registry.get("tables", [])
    if not tables:
        # Check if there are unregistered files
        files = wdr.scan_workspace_data_files(workspace_root)
        if files:
            print(
                "Workspace data files exist but are not registered.\n"
                "Run:\n"
                "  cmux-evidence data refresh\n"
            )
        else:
            print(
                "No workspace data files found.\n\n"
                "Supported formats:\n"
                "  .csv, .tsv, .parquet, .json, .jsonl\n\n"
                "Add files under data/ and run:\n"
                "  cmux-evidence data refresh"
            )
        return 0

    print(wdr.print_list_summary(registry))
    return 0


def data_refresh_command(slug: str | None = None) -> int:
    """Scan workspace data, update registry, generate source SQL."""
    try:
        workspace_root = _resolve_workspace_root_for_data(slug)
    except (TypeError, ValueError) as exc:
        return error(str(exc))

    # Load workspace metadata directly from the workspace
    evidence_json = workspace_root / ".cmux" / "evidence.json"
    if not evidence_json.exists():
        return error(f"Not an Evidence workspace: {workspace_root}")

    try:
        config = load_config(evidence_json)
    except (ValueError, OSError) as exc:
        return error(str(exc))

    metadata = load_workspace_metadata(workspace_root) or {}

    # Ensure data directory exists
    data_dir = wdr.workspace_data_dir(workspace_root)
    data_dir.mkdir(parents=True, exist_ok=True)

    # Refresh registry
    registry = wdr.refresh_workspace_data_registry(workspace_root)

    # Resolve shadow runtime root
    is_content = is_content_workspace(config, metadata)
    if is_content:
        shadow_root_value = metadata.get("shadowRuntimeRoot") or config.get("shadowRuntimeRoot")
        if not shadow_root_value:
            return error("Content-only workspace metadata is missing shadowRuntimeRoot")
        shadow_root = Path(str(shadow_root_value)).expanduser().resolve()
        root_value = metadata.get("runtimeRoot") or config.get("runtimeRoot")
        if not root_value:
            return error("Content-only workspace metadata is missing runtimeRoot")
        root = Path(str(root_value)).expanduser().resolve()
    else:
        shadow_root = workspace_root
        root = workspace_root

    # Ensure shadow runtime exists
    try:
        ensure_shadow_runtime(
            root=root,
            config=config,
            workspace_root=workspace_root,
            shadow_root=shadow_root,
            metadata=metadata,
        )
    except (OSError, ValueError) as exc:
        print(f"Warning: shadow runtime setup issue: {exc}", file=sys.stderr)

    # Generate source SQL files
    ready_tables = [t for t in registry.get("tables", []) if t.get("status") == "ready"]
    if ready_tables:
        wdr.generate_workspace_file_sources(workspace_root, shadow_root, registry)

    # Print summary
    print(wdr.print_registry_summary(registry))

    # Run Evidence sources for files if ready tables exist
    if ready_tables:
        sources_dir = shadow_root / "sources" / wdr.GENERATED_FILES_SOURCE_NAME
        if sources_dir.is_dir():
            print()
            print("Running Evidence source extraction...")
            try:
                result = subprocess.run(
                    ["npm", "run", "sources", "--", "--sources", wdr.GENERATED_FILES_SOURCE_NAME],
                    cwd=str(shadow_root),
                    check=False,
                    text=True,
                    capture_output=True,
                )
                if result.returncode == 0:
                    print("Evidence sources updated successfully.")
                else:
                    print(f"Warning: Evidence source extraction returned {result.returncode}")
                    if result.stderr:
                        print(result.stderr[:500])
            except OSError as exc:
                print(f"Warning: could not run Evidence sources: {exc}")

    return 0


def main(argv: list[str] | None = None) -> int:
    args = list(sys.argv[1:] if argv is None else argv)
    print_layout = False
    if "--print-layout" in args:
        args.remove("--print-layout")
        print_layout = True

    if not args:
        return open_workspace(".", print_layout=print_layout)

    command = args[0]
    if command in {"-h", "--help", "help"}:
        print(usage())
        return 0

    if command == "new":
        new_args = args[1:]
        open_after_create = True
        if "--no-open" in new_args:
            new_args.remove("--no-open")
            open_after_create = False
        return new_analysis(" ".join(new_args), print_layout=print_layout, open_after_create=open_after_create)

    if command == "open":
        return open_analysis(args[1] if len(args) > 1 else ".", print_layout=print_layout)

    if command == "list":
        return list_analyses()

    if command == "current":
        return current_command()

    if command == "status":
        return status_command()

    if command == "context":
        return context_command(print_context="--print" in args[1:])

    if command == "preview-url":
        return preview_url_command()

    if command == "preview-open":
        return preview_open_command()

    if command == "browser-surfaces":
        return browser_surfaces_command()

    if command == "preview-title":
        return preview_title_command(args[1:])

    if command == "preview-snapshot":
        return preview_snapshot_command(args[1:])

    if command == "preview-screenshot":
        return preview_screenshot_command(args[1:])

    if command == "validate":
        return validate_command()

    if command == "diff":
        return diff_command(stat_only="--stat" in args[1:])

    if command == "publish":
        return publish_command()

    if command == "data":
        return data_command(args[1:])

    return open_workspace(command, print_layout=print_layout)


if __name__ == "__main__":
    raise SystemExit(main())
